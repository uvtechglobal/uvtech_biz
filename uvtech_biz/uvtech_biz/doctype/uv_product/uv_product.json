{
  "doctype": "DocType",
  "name": "Uv Product",
  "module": "Uvtech Biz",
  "custom": 0,
  "istable": 0,
  "engine": "InnoDB",
  "field_order": [
    "product_name",
    "sku",
    "price",
    "stock_qty"
  ],
  "fields": [
    {
      "fieldname": "product_name",
      "fieldtype": "Data",
      "label": "Name",
      "reqd": 1
    },
    {
      "fieldname": "sku",
      "fieldtype": "Data",
      "label": "SKU",
      "reqd": 1,
      "unique": 1
    },
    {
      "fieldname": "price",
      "fieldtype": "Currency",
      "label": "Price",
      "default": 0
    },
    {
      "fieldname": "stock_qty",
      "fieldtype": "Float",
      "label": "Stock Qty",
      "default": 0
    }
  ],
  "permissions": [
    {
      "role": "Company Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Staff",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    }
  ]
}