{
  "doctype": "DocType",
  "name": "UV Sync Log",
  "module": "Uvtech Biz",
  "custom": 0,
  "istable": 0,
  "engine": "InnoDB",
  "field_order": [
    "platform",
    "status",
    "message"
  ],
  "fields": [
    {
      "fieldname": "platform",
      "fieldtype": "Data",
      "label": "Platform",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Success\nFailed",
      "default": "Success"
    },
    {
      "fieldname": "message",
      "fieldtype": "Small Text",
      "label": "Message"
    }
  ],
  "permissions": [
    {
      "role": "Company Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Staff",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    }
  ]
}